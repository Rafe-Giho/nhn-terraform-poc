object_storage_containers = {
  artifacts = {
    name = "sgh-cloud-native-dev-artifacts"
    metadata = {
      purpose = "ci-artifacts"
    }
  }
  backups = {
    name = "sgh-cloud-native-dev-backups"
    metadata = {
      purpose = "backup"
    }
  }
  logs = {
    name = "sgh-cloud-native-dev-pipeline-logs"
    metadata = {
      purpose = "pipeline-logs"
    }
  }
}
